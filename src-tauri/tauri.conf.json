{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Connexio",
  "version": "0.4.1-dev.1",
  "identifier": "com.connexio.app",
  "build": {
    "beforeDevCommand": "npm run dev:renderer",
    "devUrl": "http://localhost:5188",
    "beforeBuildCommand": "npm run build:renderer",
    "frontendDist": "../dist/renderer"
  },
  "app": {
    "windows": [
      {
        "title": "Connexio",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": false,
        "visible": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico"
      }
    },
    "category": "DeveloperTool",
    "shortDescription": "Project-based Terminal Manager",
    "longDescription": "Connexio organizes your terminals by project. Each project gets its own workspace with dedicated terminal tabs, persistent sessions, and productivity tools."
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEMzNzU4MDE0NDExNjJDNUIKUldSYkxCWkJGSUIxdzZTbzRzUjZTNVFmVFNtUmtMbmYxdW9VMXYzR0VvWVdybDNhMnJ5TmNScCsK",
      "endpoints": [
        "https://github.com/yandanp/Connexio/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
