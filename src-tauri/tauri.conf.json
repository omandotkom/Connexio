{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Connexio",
  "version": "0.4.0",
  "identifier": "com.connexio.app",
  "build": {
    "beforeDevCommand": "npm run dev:renderer",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build:renderer",
    "frontendDist": "../dist/renderer"
  },
  "app": {
    "windows": [
      {
        "title": "Connexio",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": false,
        "visible": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "appimage", "deb", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    },
    "category": "DeveloperTool",
    "shortDescription": "Project-based Terminal Manager",
    "longDescription": "Connexio organizes your terminals by project. Each project gets its own workspace with dedicated terminal tabs, persistent sessions, and productivity tools."
  },
  "plugins": {}
}
